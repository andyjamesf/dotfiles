{
  "layer": "top",
  "position": "top",

  "modules-left": [
    "hyprland/workspaces"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "network",
    "cpu",
    "memory",
    "temperature",
    "battery",
    "power-profiles-daemon"
  ],

  "clock": {
    "format": "ΎΑΩ {:%H:%M  ΎΒ│ %d-%m}",
    "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "on-click": "alacritty -e cal"
  },

  "cpu": {
    "interval": 5,
    "format": "ΎΜδ {usage}%"
  },

  "memory": {
    "interval": 5,
    "format": "≤░Ξδ {}%"
  },

  "temperature": {
    "critical-threshold": 80,
    "format": "ΎΜΚ {temperatureC}┬░C"
  },

  "network": {
    "format-wifi": "ΎΘτ {signalStrength}%",
    "format-ethernet": "≤░ΙΑ",
    "format-disconnected": "≤░Ψς"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "έγκ {capacity}%",
    "format-plugged": "ΎΘο",
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ]
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver"i: "ΎΒυ"
    }
  }
}
